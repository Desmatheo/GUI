   6:EffectPhaseShifter.cpp **** PitchShiftEffect::PitchShiftEffect(daisy::DaisySeed& hw, float sampleRate) : hardware(hw) {
   7:EffectPhaseShifter.cpp ****     // Initialisation avec la fréquence d'échantillonnage
   8:EffectPhaseShifter.cpp ****     pitchShifterL.Init(sampleRate);
   9:EffectPhaseShifter.cpp ****     pitchShifterR.Init(sampleRate);
  10:EffectPhaseShifter.cpp **** 
  11:EffectPhaseShifter.cpp ****     // Paramétrage par défaut : transposition en demi-tons
  12:EffectPhaseShifter.cpp ****     // Exemple: 12.0f = une octave au-dessus, -12.0f = une octave en-dessous
  13:EffectPhaseShifter.cpp ****     pitchShifterL.SetTransposition(12.0f);
  14:EffectPhaseShifter.cpp ****     // pitchShifterR.SetTransposition(12.0f);
  15:EffectPhaseShifter.cpp **** 
  16:EffectPhaseShifter.cpp ****     // Optionnel : ajuste la taille du delay utilisé pour l'effet.
  17:EffectPhaseShifter.cpp ****     // Un delai très court donne un effet robotique, un delai long donne de l'écho.
  18:EffectPhaseShifter.cpp ****     // pitchShifterL.SetDelSize(4800); 
  19:EffectPhaseShifter.cpp **** }
