  21:EffectPhaseShifter.cpp **** void PitchShiftEffect::update(const float** in, float** out, int idx) {
  22:EffectPhaseShifter.cpp ****     float inputL = in[0][idx];
  23:EffectPhaseShifter.cpp ****     float inputR = in[1][idx];
  24:EffectPhaseShifter.cpp **** 
  25:EffectPhaseShifter.cpp ****     // Traitement du signal par les PitchShifters
  26:EffectPhaseShifter.cpp ****     float pitch_outL = pitchShifterL.Process(inputL);
  27:EffectPhaseShifter.cpp ****     // float pitch_outR = pitchShifterR.Process(inputR);
  28:EffectPhaseShifter.cpp **** 
  29:EffectPhaseShifter.cpp ****     // Mixage Dry/Wet
