  21:../../DaisySP/Source/Effects/pitchshifter.h **** /** Shift can be 30-100 ms lets just start with 50 for now.
  22:../../DaisySP/Source/Effects/pitchshifter.h **** 0.050 * SR = 2400 samples (at 48kHz)
  23:../../DaisySP/Source/Effects/pitchshifter.h **** */
  24:../../DaisySP/Source/Effects/pitchshifter.h **** #define SHIFT_BUFFER_SIZE 16384
  25:../../DaisySP/Source/Effects/pitchshifter.h **** //#define SHIFT_BUFFER_SIZE 4800
  26:../../DaisySP/Source/Effects/pitchshifter.h **** //#define SHIFT_BUFFER_SIZE 8192
  27:../../DaisySP/Source/Effects/pitchshifter.h **** //#define SHIFT_BUFFER_SIZE 1024
  28:../../DaisySP/Source/Effects/pitchshifter.h **** 
  29:../../DaisySP/Source/Effects/pitchshifter.h **** namespace daisysp
  30:../../DaisySP/Source/Effects/pitchshifter.h **** {
  31:../../DaisySP/Source/Effects/pitchshifter.h **** static inline uint32_t hash_xs32(uint32_t x)
  32:../../DaisySP/Source/Effects/pitchshifter.h **** {
  33:../../DaisySP/Source/Effects/pitchshifter.h ****     x ^= x << 13;
  34:../../DaisySP/Source/Effects/pitchshifter.h ****     x ^= x >> 17;
  35:../../DaisySP/Source/Effects/pitchshifter.h ****     x ^= x << 5;
  36:../../DaisySP/Source/Effects/pitchshifter.h ****     return x;
  37:../../DaisySP/Source/Effects/pitchshifter.h **** }
  38:../../DaisySP/Source/Effects/pitchshifter.h **** 
  39:../../DaisySP/Source/Effects/pitchshifter.h **** inline uint32_t myrand()
  40:../../DaisySP/Source/Effects/pitchshifter.h **** {
  41:../../DaisySP/Source/Effects/pitchshifter.h ****     static uint32_t seed = 1;
  42:../../DaisySP/Source/Effects/pitchshifter.h ****     seed                 = hash_xs32(seed);
  43:../../DaisySP/Source/Effects/pitchshifter.h ****     return seed;
  44:../../DaisySP/Source/Effects/pitchshifter.h **** }
  45:../../DaisySP/Source/Effects/pitchshifter.h **** 
  46:../../DaisySP/Source/Effects/pitchshifter.h **** /**  time-domain pitchshifter
  47:../../DaisySP/Source/Effects/pitchshifter.h **** 
  48:../../DaisySP/Source/Effects/pitchshifter.h **** Author: shensley
  49:../../DaisySP/Source/Effects/pitchshifter.h **** 
  50:../../DaisySP/Source/Effects/pitchshifter.h **** Based on "Pitch Shifting" from ucsd.edu 
  51:../../DaisySP/Source/Effects/pitchshifter.h **** 
  52:../../DaisySP/Source/Effects/pitchshifter.h **** t = 1 - ((s *f) / R)
  53:../../DaisySP/Source/Effects/pitchshifter.h **** 
  54:../../DaisySP/Source/Effects/pitchshifter.h **** where:
  55:../../DaisySP/Source/Effects/pitchshifter.h ****     s is the size of the delay
  56:../../DaisySP/Source/Effects/pitchshifter.h ****     f is the frequency of the lfo
  57:../../DaisySP/Source/Effects/pitchshifter.h ****     r is the sample_rate
  58:../../DaisySP/Source/Effects/pitchshifter.h **** 
  59:../../DaisySP/Source/Effects/pitchshifter.h **** solving for t = 12.0
  60:../../DaisySP/Source/Effects/pitchshifter.h **** f = (12 - 1) * 48000 / SHIFT_BUFFER_SIZE;
  61:../../DaisySP/Source/Effects/pitchshifter.h **** 
  62:../../DaisySP/Source/Effects/pitchshifter.h **** \todo - move hash_xs32 and myrand to dsp.h and give appropriate names
  63:../../DaisySP/Source/Effects/pitchshifter.h **** */
