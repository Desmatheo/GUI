 309:Util/base_effect_module.cpp ****         }
 310:Util/base_effect_module.cpp ****     } else if (paramType == ParameterValueType::Bool) {
 311:Util/base_effect_module.cpp ****         // Set the Bool Value to False if the magnitude is less then 0.5f, true otherwise
 312:Util/base_effect_module.cpp ****         if (value < 0.5f) {
