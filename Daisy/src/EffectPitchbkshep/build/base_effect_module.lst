 260:Util/base_effect_module.cpp **** void BaseEffectModule::SetParameterAsMagnitude(int parameter_id, float value) {
 261:Util/base_effect_module.cpp ****     // Handle different ParameterValueTypes Correctly
 262:Util/base_effect_module.cpp ****     ParameterValueType paramType = GetParameterType(parameter_id);
 263:Util/base_effect_module.cpp **** 
 264:Util/base_effect_module.cpp ****     if (paramType == ParameterValueType::Raw) {
 265:Util/base_effect_module.cpp ****         // This is an unsupported operation, so do nothing.
 266:Util/base_effect_module.cpp ****         return;
