 278:Util/base_effect_module.cpp ****         }
 279:Util/base_effect_module.cpp **** 
 280:Util/base_effect_module.cpp ****         // Set the scaled parameter using the magnitude and the curve type
 281:Util/base_effect_module.cpp ****         switch (GetParameterValueCurve(parameter_id)) {
 282:Util/base_effect_module.cpp ****         case ParameterValueCurve::Log: {
 283:Util/base_effect_module.cpp ****             // Don't do log operations with a 0 or negative number,
 284:Util/base_effect_module.cpp ****             // automatically adjust value if necessary
 285:Util/base_effect_module.cpp ****             const float minToUse = std::max(0.01f, (float)min);
 286:Util/base_effect_module.cpp **** 
 287:Util/base_effect_module.cpp ****             // Logarithmic scaling: interpolate in the log domain
 288:Util/base_effect_module.cpp ****             const float tmp = std::pow(10.0, std::log10(minToUse) + value * (std::log10((float)max)
 289:Util/base_effect_module.cpp ****             SetParameterAsFloat(parameter_id, tmp);
 290:Util/base_effect_module.cpp ****             break;
 291:Util/base_effect_module.cpp ****         }
 292:Util/base_effect_module.cpp ****         case ParameterValueCurve::InverseLog: {
 293:Util/base_effect_module.cpp ****             // Don't do log operations with a 0 or negative number,
 294:Util/base_effect_module.cpp ****             // automatically adjust value if necessary
 295:Util/base_effect_module.cpp ****             const float minToUse = std::max(0.01f, (float)min);
 296:Util/base_effect_module.cpp **** 
 297:Util/base_effect_module.cpp ****             // Inverse Logarithmic scaling: reverse the mapping
 298:Util/base_effect_module.cpp ****             const float tmp = std::pow(10.0, std::log10(minToUse) + (1.0f - value) * (std::log10((f
 299:Util/base_effect_module.cpp ****             SetParameterAsFloat(parameter_id, tmp);
 300:Util/base_effect_module.cpp ****             break;
 301:Util/base_effect_module.cpp ****         }
 302:Util/base_effect_module.cpp ****         case ParameterValueCurve::Linear:
 303:Util/base_effect_module.cpp ****         default: {
 304:Util/base_effect_module.cpp ****             // Linear scaling: simple interpolation
 305:Util/base_effect_module.cpp ****             const float tmp = (value * ((float)max - (float)min) + (float)min);
