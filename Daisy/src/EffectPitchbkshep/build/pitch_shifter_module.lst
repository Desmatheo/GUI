  21:Util/../Util/RuntimeDelayLine.h ****   public:
  22:Util/../Util/RuntimeDelayLine.h ****     DelayLine() : buffer_(nullptr), size_(0), write_ptr_(0), delay_(1), frac_(0.f) {}
  23:Util/../Util/RuntimeDelayLine.h **** 
  24:Util/../Util/RuntimeDelayLine.h ****     void Init(T *buffer, size_t size) {
  25:Util/../Util/RuntimeDelayLine.h ****         buffer_ = buffer;
  26:Util/../Util/RuntimeDelayLine.h ****         size_ = size;
  27:Util/../Util/RuntimeDelayLine.h ****         Reset();
  28:Util/../Util/RuntimeDelayLine.h ****     }
  29:Util/../Util/RuntimeDelayLine.h **** 
  30:Util/../Util/RuntimeDelayLine.h ****     void Reset() {
  31:Util/../Util/RuntimeDelayLine.h ****         for (size_t i = 0; i < size_; ++i)
  32:Util/../Util/RuntimeDelayLine.h ****             buffer_[i] = T(0);
  33:Util/../Util/RuntimeDelayLine.h ****         write_ptr_ = 0;
  34:Util/../Util/RuntimeDelayLine.h ****         delay_ = 1;
  35:Util/../Util/RuntimeDelayLine.h ****         frac_ = 0.f;
  36:Util/../Util/RuntimeDelayLine.h ****     }
  37:Util/../Util/RuntimeDelayLine.h **** 
  38:Util/../Util/RuntimeDelayLine.h ****     void SetDelay(size_t delay) {
  39:Util/../Util/RuntimeDelayLine.h ****         delay_ = (delay < size_) ? delay : size_ - 1;
  40:Util/../Util/RuntimeDelayLine.h ****         frac_ = 0.f;
  41:Util/../Util/RuntimeDelayLine.h ****     }
  42:Util/../Util/RuntimeDelayLine.h **** 
  43:Util/../Util/RuntimeDelayLine.h ****     void SetDelay(float delay) {
  44:Util/../Util/RuntimeDelayLine.h ****         int32_t int_delay = static_cast<int32_t>(delay);
  45:Util/../Util/RuntimeDelayLine.h ****         frac_ = delay - static_cast<float>(int_delay);
