  21:Util/../Util/pitch_shifter.h **** 
  22:Util/../Util/pitch_shifter.h **** static inline uint32_t hash_xs32(uint32_t x) {
  23:Util/../Util/pitch_shifter.h ****     x ^= x << 13;
  24:Util/../Util/pitch_shifter.h ****     x ^= x >> 17;
  25:Util/../Util/pitch_shifter.h ****     x ^= x << 5;
  26:Util/../Util/pitch_shifter.h ****     return x;
  27:Util/../Util/pitch_shifter.h **** }
  28:Util/../Util/pitch_shifter.h **** 
  29:Util/../Util/pitch_shifter.h **** inline uint32_t myrand() {
  30:Util/../Util/pitch_shifter.h ****     static uint32_t seed = 1;
  31:Util/../Util/pitch_shifter.h ****     seed = hash_xs32(seed);
  32:Util/../Util/pitch_shifter.h ****     return seed;
  33:Util/../Util/pitch_shifter.h **** }
  34:Util/../Util/pitch_shifter.h **** 
  35:Util/../Util/pitch_shifter.h **** /**  time-domain pitchshifter
  36:Util/../Util/pitch_shifter.h **** 
  37:Util/../Util/pitch_shifter.h **** Author: shensley
  38:Util/../Util/pitch_shifter.h **** 
  39:Util/../Util/pitch_shifter.h **** Based on "Pitch Shifting" from ucsd.edu
  40:Util/../Util/pitch_shifter.h **** 
ARM GAS  /tmp/ccRb3mjQ.s 			page 9


  41:Util/../Util/pitch_shifter.h **** t = 1 - ((s *f) / R)
  42:Util/../Util/pitch_shifter.h **** 
  43:Util/../Util/pitch_shifter.h **** where:
  44:Util/../Util/pitch_shifter.h ****     s is the size of the delay
  45:Util/../Util/pitch_shifter.h ****     f is the frequency of the lfo
  46:Util/../Util/pitch_shifter.h ****     r is the sample_rate
  47:Util/../Util/pitch_shifter.h **** 
  48:Util/../Util/pitch_shifter.h **** solving for t = 12.0
  49:Util/../Util/pitch_shifter.h **** f = (12 - 1) * 48000 / delaySize;
  50:Util/../Util/pitch_shifter.h **** 
  51:Util/../Util/pitch_shifter.h **** \todo - move hash_xs32 and myrand to dsp.h and give appropriate names
  52:Util/../Util/pitch_shifter.h **** */
