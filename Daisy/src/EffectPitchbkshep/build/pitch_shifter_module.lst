  15:pitch_shifter_module.cpp **** // How many samples to delay to based on the "Delay" knob and parameter
  16:pitch_shifter_module.cpp **** // when the time knob is set to max, this is used for the ramp up/down
  17:pitch_shifter_module.cpp **** // transition when in momentary mode. Has no effect on latching mode
  18:pitch_shifter_module.cpp **** const uint32_t k_maxSamplesMaxTime = 48000 * 2;
  19:pitch_shifter_module.cpp **** 
  20:pitch_shifter_module.cpp **** // Larger delay size is higher fidelity/quality for a farther transpose, at
  21:pitch_shifter_module.cpp **** // the cost of additional latency (like...a lot of latency)
  22:pitch_shifter_module.cpp **** // 2048 works pretty well for 1 semitone and is ~42ms
  23:pitch_shifter_module.cpp **** // 6000 samples was the best I could find for a usable full octave tone,
  24:pitch_shifter_module.cpp **** // but is a whopping 125 ms, nearly unusable? kind of cool when blended
  25:pitch_shifter_module.cpp **** // with the dry signal though
