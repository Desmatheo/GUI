 183:pitch_shifter_module.cpp ****         m_samplesToDelayReturn = static_cast<uint32_t>(static_cast<float>(k_maxSamplesMaxTime) * Ge
 184:pitch_shifter_module.cpp ****     }
 185:pitch_shifter_module.cpp **** 
 186:pitch_shifter_module.cpp ****     // Parameters changed, reset the transposition target just in case (mostly
 187:pitch_shifter_module.cpp ****     // impacts momentary/latch and delay)
 188:pitch_shifter_module.cpp ****     SetTranspose(m_semitoneTarget);
