 129:pitch_shifter_module.cpp ****     if (m_latching) {
 130:pitch_shifter_module.cpp ****         // Value between 0 and 1 where 0 is 1 semitone and 1 is 12 semitones
 131:pitch_shifter_module.cpp ****         const float interpolateValue = (std::abs(semitone) - 1.0f) / 11.0f;
 132:pitch_shifter_module.cpp **** 
