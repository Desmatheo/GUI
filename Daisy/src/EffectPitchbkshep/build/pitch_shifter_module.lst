 168:pitch_shifter_module.cpp ****     if (parameter_id == SEMITONE || parameter_id == DIRECTION) {
 169:pitch_shifter_module.cpp ****         m_directionDown = GetParameterAsBinnedValue(DIRECTION) == 1;
 170:pitch_shifter_module.cpp **** 
