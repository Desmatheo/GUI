  26:Earth.cpp     ****     float inputDampHigh = 0.;
  27:Earth.cpp     ****     float reverbDampLow = 0.;
  28:Earth.cpp     ****     float reverbDampHigh = 0.;
  29:Earth.cpp     ****     float diffusion = 1.;
  30:Earth.cpp     **** 
  31:Earth.cpp     ****     reverb.setSampleRate(sampleRate);
  32:Earth.cpp     **** 
  33:Earth.cpp     ****     reverb.setTimeScale(4.0);
  34:Earth.cpp     ****     reverb.setPreDelay(0.0);
  35:Earth.cpp     **** 
  36:Earth.cpp     ****     reverb.setInputFilterLowCutoffPitch(10. * inputDampLow);
  37:Earth.cpp     ****     reverb.setInputFilterHighCutoffPitch(10. - (10. * inputDampHigh));
  38:Earth.cpp     ****     reverb.enableInputDiffusion(true);
