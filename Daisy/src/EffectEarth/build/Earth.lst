  43:Earth.cpp     ****     reverb.setTankModSpeed(1.0);
  44:Earth.cpp     ****     reverb.setTankModDepth(0.5);
  45:Earth.cpp     ****     reverb.setTankModShape(0.5); // <-- currently not controllable, maybe use dipswitch for differe
  46:Earth.cpp     ****     reverb.clear();
  47:Earth.cpp     **** 
