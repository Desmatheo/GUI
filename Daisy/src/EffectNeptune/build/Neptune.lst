  34:Neptune.cpp   **** // Structure pour gérer un canal de delay
  35:Neptune.cpp   **** struct delay
  36:Neptune.cpp   **** {
  37:Neptune.cpp   ****     DelayLineOct<float, MAX_DELAY> *del;
  38:Neptune.cpp   ****     float                        currentDelay;
  39:Neptune.cpp   ****     float                        delayTarget;
  40:Neptune.cpp   ****     float                        feedback = 0.0;
  41:Neptune.cpp   ****     float                        active = false;
  42:Neptune.cpp   ****     
  43:Neptune.cpp   ****     float Process(float in)
  44:Neptune.cpp   ****     {
  45:Neptune.cpp   ****         // Lissage du temps de delay pour éviter les clics
  46:Neptune.cpp   ****         fonepole(currentDelay, delayTarget, .0002f);    // Va de CurrentDelay à delayTarget avec u
  47:Neptune.cpp   ****         del->SetDelay(currentDelay);
  48:Neptune.cpp   **** 
  49:Neptune.cpp   ****         // Lecture du son retardé
  50:Neptune.cpp   ****         float del_read = del->Read();                   // Recupere le sample au delay demandé
  51:Neptune.cpp   **** 
  52:Neptune.cpp   ****         // Application du filtre passe-bas
  53:Neptune.cpp   ****         float read = toneOctLP.Process(del_read);       // Filtre Tone pour que ça sonne moins agg
  54:Neptune.cpp   **** 
  55:Neptune.cpp   ****         // Écriture dans la ligne de delay (avec feedback)
  56:Neptune.cpp   ****         if (active) {
  57:Neptune.cpp   ****             del->Write((feedback * read) + in);
  58:Neptune.cpp   ****         } else {
  59:Neptune.cpp   ****             del->Write(feedback * read);                // Si inactif, seul le feedback est réinje
  60:Neptune.cpp   ****         }
  61:Neptune.cpp   **** 
  62:Neptune.cpp   ****         return read;
  63:Neptune.cpp   ****     }
