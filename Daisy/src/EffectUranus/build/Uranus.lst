   1:granularplayermod.h **** /*
   2:granularplayermod.h **** Copyright (c) 2020 Electrosmith, Corp, Vinícius Fernandes
   3:granularplayermod.h **** 
   4:granularplayermod.h **** Use of this source code is governed by an MIT-style
